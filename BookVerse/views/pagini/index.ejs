<!DOCTYPE html>
<html lang="ro">
<head>
    <title>BookVerse - Homepage</title>
    <%- include('../fragmente/head.ejs') %>
</head>
<body>

    <%- include('../fragmente/header.ejs') %>

    <!-- ========================================================== -->
    <!-- TEXT PLIMBĂREȚ - MUTAT AICI (Între Header și Bun Venit)    -->
    <!-- ========================================================== -->
    <div class="container-text-plimbaret">
        <div class="text-plimbaret">🚨 Nu rata ocazia! Săptămâna viitoare avem reduceri masive de Black Friday la toate cărțile de SF! Transport gratuit la comenzi peste 100 RON! 🚨</div>
    </div>

    <main>
        <!-- 1. HARTA INTERACTIVĂ (BUN VENIT) -->
        <section id="harta-interactiva">
            <div class="text-prezentare">
                <h2 class="text-reflexie" data-text="Bun venit la BookVerse!">Bun venit la BookVerse!</h2>
                <p>Bucuria lecturii te așteaptă. Descoperă mii de titluri, bestseller-uri și oferte speciale în librăria noastră online.</p>
                <p><strong>Explorează vizual:</strong> Dă click pe rafturile din imaginea alăturată pentru a naviga rapid către secțiunile dorite (Program, Evenimente, Cartea Săptămânii).</p>
            </div>
            <div class="imagine-harta">
                <img src="./resurse/imagini/biblioteca-virtuala_large.jpg" usemap="#image-map" alt="Hartă interactivă a bibliotecii">
                <map name="image-map">
                    <area shape="rect" coords="298,0,730,583" href="#orar" alt="Program de Funcționare BookVerse" title="Mergi la Program de Funcționare BookVerse">
                    <area shape="rect" coords="0,0,290,580" href="#evenimente" alt="Evenimente și Noutăți BookVerse" title="Mergi la Evenimente și Noutăți BookVerse">
                    <area shape="rect" coords="736,9,1006,579" href="#cartea-saptamanii" alt="Cartea Săptămânii" title="Mergi la Cartea Săptămânii">
                </map>
            </div>
        </section>

        <!-- 2. PREZENTARE VIDEO (ACUM E PE RÂNDUL 2) -->
        <section id="prezentare-video">
            <h2 style="color: var(--culoare-primara); margin-bottom: 10px; text-align: center;">Prezentare BookVerse</h2>
            <p style="margin-bottom: 15px; border: none; text-align: center;">Urmărește un scurt videoclip despre librăria noastră:</p>
            
            <video preload="metadata" controls poster="/resurse/imagini/poster-video.jpg" style="width: 100%; max-width: 800px; margin: 0 auto; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.2);">
                <source src="/resurse/video/prezentare.mp4" type="video/mp4">
                <source src="/resurse/video/prezentare.webm" type="video/webm">
                <track src="/resurse/vtt/bookverse-ro.vtt" kind="captions" srclang="ro" label="Română" default>
                <track src="/resurse/vtt/bookverse-en.vtt" kind="captions" srclang="en" label="English">
                Browser-ul tău nu suportă elementul video.
            </video>
        </section>

        <!-- 3. USERI, STATISTICI, SERVER -->
        <section id="useri-online">
            <h2>Utilizatori online</h2>
            <p>În prezent sunt 43 de vizitatori activi pe BookVerse! Mulțumim!</p>
        </section>

        <section id="statistici-user">
            <h2>Statistici Trade-In</h2>
            <p>În această lună, prin programul nostru de Trade-in, ai economisit 150 de RON prin vânzarea celor 5 cărți cumpărate în această lună.</p>
        </section>

        <section id="data-server">
            <h2>Status Server</h2>
            <p>Uptime server: 99.9%. Versiune platformă: v2.4.1. Trafic criptat: Activ.</p>
        </section>

        <!-- 4. GALERIE FOTO STATICĂ -->
        <section id="sectiune-galerie-statica">
            <h2>Galerie Foto - BookVerse</h2>
            <div id="grid-galerie-statica">
                <figure class="item-galerie item-1"><img src="./resurse/imagini/galerie/carte1.jpg" alt="Magia dintre pagini" title="Magia dintre pagini"><figcaption><span class="index-roman-galerie"></span>Magia dintre pagini</figcaption></figure>
                <figure class="item-galerie item-2"><img src="./resurse/imagini/galerie/carte2.jpg" alt="Rafturi fermecate" title="Rafturi fermecate"><figcaption><span class="index-roman-galerie"></span>Rafturi fermecate</figcaption></figure>
                <figure class="item-galerie item-3"><img src="./resurse/imagini/galerie/carte3.jpg" alt="Colțul de lectură" title="Colțul de lectură"><figcaption><span class="index-roman-galerie"></span>Colțul de lectură</figcaption></figure>
                <figure class="item-galerie item-4"><img src="./resurse/imagini/galerie/carte4.jpg" alt="Fațada librăriei" title="Fațada librăriei"><figcaption><span class="index-roman-galerie"></span>Fațada librăriei</figcaption></figure>
                <figure class="item-galerie item-5"><img src="./resurse/imagini/galerie/carte5.jpg" alt="Liniștea serii" title="Liniștea serii"><figcaption><span class="index-roman-galerie"></span>Liniștea serii</figcaption></figure>
                <figure class="item-galerie item-6"><img src="./resurse/imagini/galerie/carte6.jpg" alt="Studiu intens" title="Studiu intens"><figcaption><span class="index-roman-galerie"></span>Studiu intens</figcaption></figure>
                <figure class="item-galerie item-7"><img src="./resurse/imagini/galerie/carte7.jpg" alt="Anticariat" title="Anticariat"><figcaption><span class="index-roman-galerie"></span>Anticariat</figcaption></figure>
                <figure class="item-galerie item-8"><img src="./resurse/imagini/galerie/carte8.jpg" alt="Colecție rară" title="Colecție rară"><figcaption><span class="index-roman-galerie"></span>Colecție rară</figcaption></figure>
                <figure class="item-galerie item-9"><img src="./resurse/imagini/galerie/carte9.jpg" alt="Universuri literare" title="Universuri literare"><figcaption><span class="index-roman-galerie"></span>Universuri literare</figcaption></figure>
                <figure class="item-galerie item-10"><img src="./resurse/imagini/galerie/carte10.jpg" alt="Relaxare și cafea" title="Relaxare și cafea"><figcaption><span class="index-roman-galerie"></span>Relaxare și cafea</figcaption></figure>
                <figure class="item-galerie item-11"><img src="./resurse/imagini/galerie/carte11.jpg" alt="Romane clasice" title="Romane clasice"><figcaption><span class="index-roman-galerie"></span>Romane clasice</figcaption></figure>
                <figure class="item-galerie item-12"><img src="./resurse/imagini/galerie/carte12.jpg" alt="Cărți deschise" title="Cărți deschise"><figcaption><span class="index-roman-galerie"></span>Cărți deschise</figcaption></figure>
                <figure class="item-galerie item-13"><img src="./resurse/imagini/galerie/carte13.jpg" alt="Povești nemuritoare" title="Povești nemuritoare"><figcaption><span class="index-roman-galerie"></span>Povești nemuritoare</figcaption></figure>
            </div>
        </section>

        <hr class="separator-balonase">

        <!-- 6. EVENIMENTE -->
        <section id="evenimente">
            <h2><i class="fa-solid fa-bell fa-shake" style="color: #E67E22;"></i> Evenimente și Noutăți BookVerse</h2>
            <p>Fii la curent cu cele mai noi oferte din <b>libraria noastra online</b>. Participă la evenimentele lunare pentru a prinde cele mai bune <b>reduceri la carti</b> și publicații!</p>
            <ul>
                <li><time datetime="2024-04-15T10:00">15 Aprilie, ora 10:00</time> - <b>Lansarea programului Trade-In</b>.</li>
                <li><time datetime="2024-04-23T12:00">23 Aprilie, ora 12:00</time> - <b>Ziua Internațională a Cărții</b>.</li>
                <li><time datetime="2024-05-01T09:00">1 Mai, ora 09:00</time> - <b>Târgul de Primăvară BookVerse</b>.</li>
            </ul>
        </section>

        <!-- 7. TABELE -->
        <aside id="zona2-tabele">
            <section id="orar" style="border: none; box-shadow: none; padding: 0;">
                <h2>Program de Funcționare BookVerse</h2>
                <div class="container-tabel">
                    <table id="tab-orar-simplu">
                        <caption>Orar Suport Clienți și Recepție Colete</caption>
                        <thead><tr><th>Cod</th><th>Perioadă</th><th>Zi</th><th>Interval dimineață</th><th>Pauză de masă</th><th>Interval seară</th></tr></thead>
                        <tbody>
                            <tr><td></td><td rowspan="5">Zile<br/>Lucrătoare</td><td>Luni</td><td>10-12</td><td>12-14</td><td>14-20</td></tr>
                            <tr><td></td><td>Marți</td><td>9-12</td><td>12-14</td><td>14-21</td></tr>
                            <tr><td></td><td>Miercuri</td><td>9-11</td><td>11-13</td><td>14-21</td></tr>
                            <tr><td></td><td>Joi</td><td>9-11</td><td>11-13</td><td>14-21</td></tr>
                            <tr><td></td><td>Vineri</td><td>9-12</td><td>12-14</td><td>14-19</td></tr>
                            <tr><td></td><td rowspan="2">Weekend</td><td>Sâmbătă</td><td>10-12</td><td>12-13</td><td>13-16</td></tr>
                            <tr><td></td><td>Duminică</td><td>10-14</td><td>-</td><td>Închis</td></tr>
                        </tbody>
                        <tfoot><tr><td colspan="6">Închis cu ocazia sărbătorilor legale, sau când suntem prea prinși citind o carte bună.</td></tr></tfoot>
                    </table>
                </div>
            </section>
            <section id="oferte-abonamente" style="border: none; box-shadow: none; padding: 0;">
                <h2>Abonamente și Oferte BookVerse</h2>
                <div class="container-tabel">
                    <table id="tab-oferte">
                        <caption>* Prețurile includ TVA. Pachetele anuale beneficiază de o lună gratuită la reînnoire.</caption>
                        <thead><tr><th>Nume Pachet</th><th>Beneficii Incluse</th><th>Tip Livrare</th><th>Preț Lunar</th></tr></thead>
                        <tbody>
                            <tr><td>Cititor Ocazional</td><td>Acces la reduceri standard</td><td>Standard (15 RON)</td><td>Gratuit</td></tr>
                            <tr><td>Explorator</td><td>1 Carte fizică cadou / lună</td><td>Standard (15 RON)</td><td>39 RON</td></tr>
                            <tr><td>Avid Reader</td><td>3 Cărți cadou + Trade-In VIP</td><td>Gratuită (Prioritară)</td><td>89 RON</td></tr>
                            <tr><td>Colecționar</td><td>5 Cărți + Acces la evenimente</td><td>Gratuită (Prioritară)</td><td>149 RON</td></tr>
                        </tbody>
                        <tfoot><tr><td colspan="3">Reducere pentru elevi, studenți și profesori</td><td>-15%</td></tr></tfoot>
                    </table>
                </div>
            </section>
        </aside>

        <!-- 8. CARTEA SĂPTĂMÂNII -->
        <section id="cartea-saptamanii">
            <h2>Cartea Săptămânii</h2>
            <p>Săptămâna aceasta vă recomandăm un bestseller internațional care nu trebuie să lipsească din nicio bibliotecă.</p>
            <section id="status-stocuri">
                <h2>Statistici și Recenzii</h2>
                <article>
                    <h3>Dune - Frank Herbert</h3>
                    <p><strong>Scor recenzii:</strong> <meter min="0" max="5" value="4.8">4.8/5</meter></p>
                    <p><strong>Stoc depozit:</strong> <meter min="0" max="100" value="15" low="20" high="80" optimum="100">15%</meter> <span style="color: red;">(Stoc critic!)</span></p>
                </article>
                <article style="margin-top: 15px;">
                    <h3>Atomic Habits - James Clear</h3>
                    <p><strong>Scor recenzii:</strong> <meter min="0" max="5" value="4.9">4.9/5</meter></p>
                    <p><strong>Stoc depozit:</strong> <meter min="0" max="100" value="85" low="20" high="80" optimum="100">85%</meter> <span style="color: green;">(În stoc)</span></p>
                </article>
            </section>
            <blockquote>"O capodoperă absolută a literaturii moderne!" - Maria Popescu</blockquote>
        </section>

        <!-- 9. CATEGORII PRINCIPALE -->
        <section id="categorii-principale">
            <h2>Categorii și Servicii</h2>
            <article><h3>Publicații și Cărți</h3><p>Oferim o gamă variată care include manuale, cărți științifice...</p></article>
            <article><h3>Pachete Promoționale</h3><p>Profită acum de oferta lunii...</p></article>
            <aside>
                <h3>Sistemul Trade-In</h3>
                <p>O funcționalitate distinctă a site-ului nostru...</p>
                <div id="formula-calcul" style="margin-top: 20px; padding: 10px; background-color: #f9f9f9; border-left: 4px solid #333;">
                    <div class="container-formula-voucher">
                        <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
                            <mi class="rezultat-voucher">Voucher</mi>
                            <mo class="operator">=</mo>
                            <mfrac><msub class="pret-baza"><mi>Preț</mi><mtext>bază</mtext></msub><mn class="numar-impartitor">2</mn></mfrac>
                            <mo class="operator">-</mo><mi class="variabila-uzura">Uzură</mi>
                            <mo class="operator">+</mo><mi class="variabila-bonus">Bonus</mi>
                        </math>
                    </div>
                </div>
            </aside>
        </section>

        <!-- 10. RESURSE UTILE -->
        <section id="resurse-utile">
            <h2>Resurse și Materiale</h2>
            <p>Pentru recenzii internaționale, verificați <a href="https://www.goodreads.com" target="_blank">Goodreads</a>.</p>
            <section id="faq">
                <h2>Întrebări Frecvente (FAQ)</h2>
                <details><summary>Cum funcționează Trade-In?</summary><p>Este foarte simplu...</p></details>
                <details><summary>Costuri livrare?</summary><p>15 RON. Gratuit peste 150 RON!</p></details>
            </section>
            <a href="./resurse/imagini/biblioteca-virtuala_large.jpg" class="container-duotone" style="display: block; max-width: 200px; margin: 10px 0;">
                <img src="./resurse/imagini/carti-mic.jpg" alt="Click pentru mărire" style="width: 100%; border: 1px solid black;" />
            </a>
            <p style="margin-top: 15px;"><a href="./resurse/imagini/oferta.txt" download>Descarcă de aici catalogul</a></p>    
        </section>   

        <!-- 11. AMBIANȚĂ ȘI PLAYLIST -->
        <section id="ambianta-lectura">
            <h2>Ambianță pentru Lectură</h2>
            <div class="container-iframe">
                <div class="taburi-iframe">
                    <a href="https://www.youtube.com/embed/L_LUpnjgPso?controls=1" target="ifr-video">🔥 Șemineu</a>
                    <a href="https://www.youtube.com/embed/mPZkdNFkNps?controls=1" target="ifr-video">🌧️ Ploaie</a>
                </div>
                <iframe name="ifr-video" src="https://www.youtube.com/embed/L_LUpnjgPso?controls=1" allowfullscreen></iframe>
            </div>
        </section>

        <section id="playlist-ambiant">
            <h2>Playlist Sunete BookVerse</h2>
            <iframe width="100%" height="315" src="https://www.youtube.com/embed/jfKfPfyJRdk" style="border: none;" allowfullscreen></iframe>
        </section>

        <!-- 12. CLUBUL DE LECTURĂ -->
        <section id="club-lectura">
            <h2>Clubul de Lectură BookVerse</h2>
            <p>Alătură-te comunității noastre! Abonează-te la newsletter și primești <strong>10% reducere</strong>.</p>
            <form action="#" method="get" class="formular-abonare">
                <input type="email" placeholder="Introdu adresa ta de e-mail..." required>
                <button type="submit">Mă abonez</button>
            </form>
        </section> 
        
         <!-- 14. DOCUMENTE OFICIALE (ULTIMUL) -->
        <section id="documente-oficiale">
            <h2>Termeni, Condiții și Retur</h2>
            <iframe src="./resurse/imagini/Termeni_și_Condiții.pdf" style="width: 100%; height: 500px; border: 1px solid var(--culoare-contur); border-radius: 8px;"></iframe>
        </section>

        <!-- 13. BOOTSTRAP (PENULTIMUL) -->
        <section id="demo-bootstrap" class="container-fluid my-5 p-4 bg-light shadow">
            <h1 class="text-primary text-center mb-4">Demo Bootstrap Custom</h1>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="card h-100 border-secondary">
                        <div class="card-body">
                            <h2 class="card-title text-secondary">Card cu colțuri mari</h2>
                            <p class="card-text">Acest card folosește raza de border modificată (border-radius: 1.5rem) și fontul Lora.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="alert alert-danger" role="alert">Aceasta este o alertă!</div>
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary" type="button">Buton Primary</button>
                        <button class="btn btn-secondary" type="button">Buton Secondary</button>
                    </div>
                </div>
            </div>
        </section>

       

    </main>

    <%- include('../fragmente/footer.ejs') %>

</body>
</html>
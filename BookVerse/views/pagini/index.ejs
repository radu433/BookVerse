                    <mfrac>
                    <msub class="pret-baza">
                        <mi>Preț</mi>
                        <mtext>bază</mtext>
                    </msub>
                    <mn class="numar-impartitor">2</mn>
                    </mfrac>
                    
                    <mo class="operator">-</mo>
                    
                    <mi class="variabila-uzura">Uzură</mi>
                    
                    <mo class="operator">+</mo>
                    
